---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  const tags = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      if (!tags.has(tag)) tags.set(tag, []);
      tags.get(tag)!.push(post);
    }
  }
  return [...tags.entries()].map(([tag, taggedPosts]) => ({
    params: { tag },
    props: {
      tag,
      posts: taggedPosts.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={`#${tag}`} description={`Posts tagged ${tag}`}>
  <h1>#{tag}</h1>
  <p class="muted">{posts.length} post{posts.length === 1 ? '' : 's'}</p>
  <PostList posts={posts} />
</Base>
