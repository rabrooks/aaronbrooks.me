---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
---

<Base
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  ogImage={post.data.heroImage?.src}
>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
        {post.data.updatedDate && (
          <>
            <span class="sep">·</span>
            <span>updated {fmtDate(post.data.updatedDate)}</span>
          </>
        )}
        {post.data.tags.length > 0 && (
          <>
            <span class="sep">·</span>
            <span class="tags">
              {post.data.tags.map((t, i) => (
                <>
                  {i > 0 && ', '}
                  <a href={`/tags/${t}/`}>{t}</a>
                </>
              ))}
            </span>
          </>
        )}
      </p>
    </header>

    {post.data.heroImage && (
      <Image
        src={post.data.heroImage}
        alt={post.data.heroAlt ?? ''}
        class="hero"
        loading="eager"
      />
    )}

    <Content />
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }
  .hero {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 0 0 2.5rem;
  }
  .post-header h1 {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.9rem;
    line-height: 1.2;
  }
  .meta {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    margin: 0;
  }
  .sep {
    margin: 0 0.5rem;
  }
  .tags a {
    color: var(--muted);
    border-bottom: none;
  }
  .tags a:hover {
    color: var(--link);
  }
</style>
